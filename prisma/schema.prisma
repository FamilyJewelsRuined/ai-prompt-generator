// Prisma schema file generated based on ERD requirements

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PromptStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  prompts Prompt[]

  @@map("users")
}

model AIModel {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text

  prompts Prompt[]

  @@map("ai_models")
}

model Prompt {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  modelId        String       @map("model_id")
  title          String
  originalPrompt String       @map("original_prompt") @db.Text
  intent         String
  finalPrompt    String?      @map("final_prompt") @db.Text
  status         PromptStatus @default(DRAFT)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  model AIModel @relation(fields: [modelId], references: [id], onDelete: Restrict)

  revisions PromptRevision[]
  answers   PromptAnswer[]
  feedbacks PromptFeedback[]

  @@index([userId])
  @@index([modelId])
  @@map("prompts")
}

model PromptRevision {
  id                    String   @id @default(cuid())
  promptId              String   @map("prompt_id")
  revisionNumber        Int      @map("revision_number")
  promptText            String   @map("prompt_text") @db.Text
  additionalRequirement String?  @map("additional_requirement") @db.Text
  createdAt             DateTime @default(now()) @map("created_at")

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@map("prompt_revisions")
}

model InterviewQuestion {
  id            String   @id @default(cuid())
  intent        String
  question      String   @db.Text
  questionOrder Int      @map("question_order")
  isRequired    Boolean  @default(true) @map("is_required")

  answers PromptAnswer[]

  @@index([intent])
  @@map("interview_questions")
}

model PromptAnswer {
  id         String @id @default(cuid())
  promptId   String @map("prompt_id")
  questionId String @map("question_id")
  answer     String @db.Text

  prompt   Prompt            @relation(fields: [promptId], references: [id], onDelete: Cascade)
  question InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@index([questionId])
  @@map("prompt_answers")
}

model PromptFeedback {
  id                    String   @id @default(cuid())
  promptId              String   @map("prompt_id")
  isSatisfied           Boolean  @map("is_satisfied")
  additionalRequirement String?  @map("additional_requirement") @db.Text
  createdAt             DateTime @default(now()) @map("created_at")

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@map("prompt_feedback")
}
